<%- include("headpartial.ejs") %>

<main>
    <div class="content-container">
        
        <% if (isAdmin && !isAdminViewingUser) { %>
            <!-- Admin Panel -->
            <div class="admin-notice">🔑 Admin Panel</div>
            <h1>All Users</h1>
            
            <ul class="recipe-list">
                <% users.forEach(user => { %>
                    <li>
                        <a href="/<%= user.id %>/recipes">
                            <%= user.username %> 
                            <small>(<%= user.role || 'user' %>)</small>
                        </a>
                    </li>
                <% }) %>
            </ul>

        <% } else if (isAdmin && isAdminViewingUser) { %>
            <!-- Admin viewing specific user -->
            <h1>Recipes of <%= viewedUserEmail %></h1>
            <p><a href="/welcome">← Back to all users</a></p>
            
            <ul class="recipe-list">
                <% recipes.forEach(recipe => { %>
                    <li>
                        <a href="/recipes/<%= user_ID %>/<%= recipe.id %>">
                            <%= recipe.name %>
                        </a>
                        <span style="float:right;">
                            <a href="/recipes/<%= user_ID %>/<%= recipe.id %>/delete" style="margin-right:15px;">Delete</a>
                            <a href="/recipes/<%= user_ID %>/<%= recipe.id %>/edit" style="margin-right:15px;">Edit</a>
                        </span>
                    </li>
                <% }) %>
            </ul>

            <a href="/add-recipe-for-user/<%= viewedUserID %>" class="navy-button">Add New Recipe for <%= viewedUserEmail %></a>

        <% } else { %>
            <!-- Regular User View -->
            <h1>Welcome back, <%= username %> 👋</h1>
            
            <h2 style="text-align:center; margin: 20px 0; color:#555;">Your Recipes</h2>
            
            <% if (recipes.length === 0) { %>
                <p style="text-align:center; color:#666; font-size:1.1rem;">
                    You don't have any recipes yet.<br>
                    Start creating your first one!
                </p>
            <% } else { %>
                <ul class="recipe-list">
                    <% recipes.forEach(recipe => { %>
                        <li>
                            <a href="/recipes/<%= user_ID %>/<%= recipe.id %>">
                                <%= recipe.name %>
                            </a>
                            <span style="float:right;">
                                <a href="/recipes/<%= user_ID %>/<%= recipe.id %>/delete" style="margin-right:15px;">Delete</a>
                            </span>
                        </li>
                    <% }) %>
                </ul>
            <% } %>

            <a href="/add-recipe/<%= user_ID %>" class="navy-button">+ Add New Recipe</a>
        <% } %>
    </div>
</main>

<%- include("footpartial.ejs") %>