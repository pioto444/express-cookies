<%- include("headpartial.ejs") %>

<main>
    <h1>Edit Recipe</h1>
    <p><strong>Owner:</strong> <%= recipe.user_email || 'legacy' %></p>

    <form action="/recipes/<%= userEmail %>/<%= recipe.id %>/edit" method="POST">
        <label for="name">Recipe Name:</label><br>
        <input type="text" id="name" name="name" value="<%= recipe.name %>" required style="width: 400px; padding: 8px;"><br><br>
        
        <button type="submit">Save Changes</button>
        <a href="/recipes/<%= userEmail %>/<%= recipe.id %>">Cancel</a>
    </form>

    <br>
    <a href="/welcome">← Back to Admin Panel</a>
</main>

<%- include("footpartial.ejs") %>